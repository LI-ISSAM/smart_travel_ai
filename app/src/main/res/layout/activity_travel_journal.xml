<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FAFAFA"
    android:fitsSystemWindows="true">

    <!-- ═══ HEADER ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="16dp"
        android:paddingTop="20dp"
        android:paddingBottom="16dp"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:text="Journal de Voyage"
                android:textColor="#000000"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="Vos souvenirs enrichis par l'IA"
                android:textColor="#AAAAAA"
                android:textSize="12sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnHeaderProfile"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:src="@android:drawable/ic_menu_my_calendar"
            android:background="#333333"
            android:padding="8dp"
            android:contentDescription="Profil"/>
    </LinearLayout>

    <ProgressBar
        android:id="@+id/journalProgressBar"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        style="?android:attr/progressBarStyleHorizontal"
        android:indeterminate="true"
        android:visibility="gone"/>

    <!-- ═══ CONTENU ═══ -->
    <ScrollView
        android:id="@+id/journalScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Boutons d'action -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <Button
                    android:id="@+id/btnAddJournalEntry"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="+ Ajouter un lieu"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:backgroundTint="#000000"
                    android:layout_marginEnd="8dp"/>

                <Button
                    android:id="@+id/btnGenerateRecap"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text=" Récit IA"
                    android:textColor="#000000"
                    android:textSize="13sp"
                    android:backgroundTint="#F0F0F0"
                    android:enabled="false"
                    android:alpha="0.4"
                    android:layout_marginStart="8dp"/>
            </LinearLayout>

            <!-- ✅ FIX : visibility="visible" pour que l'état vide s'affiche au chargement -->
            <LinearLayout
                android:id="@+id/layoutJournalEmpty"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="visible">

                <TextView
                    android:text=""
                    android:textSize="52sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:text="Votre journal est vide"
                    android:textColor="#555555"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"/>

                <TextView
                    android:text="Appuyez sur + pour ajouter votre premier lieu visité"
                    android:textColor="#999999"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"/>
            </LinearLayout>

            <!-- Carte du récit IA (cachée par défaut) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardRecap"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#000000"
                android:layout_marginBottom="16dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:text=" Récit de votre voyage"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:text="Généré par l'IA"
                        android:textColor="#888888"
                        android:textSize="11sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"/>

                    <View
                        android:layout_width="30dp"
                        android:layout_height="2dp"
                        android:background="#FFFFFF"
                        android:layout_marginBottom="14dp"/>

                    <TextView
                        android:id="@+id/tvRecapText"
                        android:textColor="#EEEEEE"
                        android:textSize="14sp"
                        android:lineSpacingMultiplier="1.6"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Entrées du journal (ajoutées dynamiquement) -->
            <LinearLayout
                android:id="@+id/layoutJournalEntries"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>
        </LinearLayout>
    </ScrollView>

    <!-- ═══ BOTTOM NAVIGATION ═══ -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigationView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:elevation="8dp"
        app:itemIconTint="#000000"
        app:itemTextColor="#000000"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_nav_menu"/>

</LinearLayout>