<?xml version="1.0" encoding="utf-8"?>
<!-- dialog_add_journal_entry.xml — Formulaire d'ajout d'entrée journal -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#FFFFFF">

    <!-- Nom du lieu -->
    <TextView
        android:text=" Lieu visité"
        android:textColor="#000000"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/etJournalPlaceName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Ex: Mosquée Hassan II, Jemaa el-Fna..."
        android:textColor="#000000"
        android:textColorHint="#999999"
        android:inputType="text"
        android:background="@android:drawable/editbox_background"
        android:padding="12dp"
        android:textSize="14sp"
        android:layout_marginBottom="16dp"/>

    <!-- Note personnelle -->
    <TextView
        android:text=" Votre ressenti (optionnel)"
        android:textColor="#000000"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/etJournalNote"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Décrivez votre expérience..."
        android:textColor="#000000"
        android:textColorHint="#999999"
        android:inputType="textMultiLine"
        android:minLines="3"
        android:maxLines="4"
        android:background="@android:drawable/editbox_background"
        android:padding="12dp"
        android:textSize="14sp"
        android:gravity="top"
        android:layout_marginBottom="16dp"/>

    <!-- Note étoiles -->
    <TextView
        android:text=" Votre note"
        android:textColor="#000000"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"/>

    <RatingBar
        android:id="@+id/journalRatingBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:numStars="5"
        android:stepSize="0.5"
        android:rating="4.0"
        android:progressTint="#000000"
        android:secondaryProgressTint="#E0E0E0"
        android:layout_marginBottom="16dp"/>

    <!-- Photo optionnelle -->
    <Button
        android:id="@+id/btnPickJournalPhoto"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:text=" Ajouter une photo (optionnel)"
        android:textSize="13sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#000000"
        android:layout_marginBottom="12dp"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

    <ImageView
        android:id="@+id/ivJournalEntryPhoto"
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:scaleType="centerCrop"
        android:visibility="gone"
        android:background="#F5F5F5"
        android:layout_marginBottom="12dp"/>

    <!-- Info IA -->
    <TextView
        android:text="L'IA va générer une description narrative de votre visite"
        android:textColor="#888888"
        android:textSize="11sp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"/>

</LinearLayout>